# Production Environment Profile

ENVIRONMENT=prod
DEBUG=false

# Database (RDS Multi-AZ)
POSTGRES_HOST=prod-postgres.c9akciq32.us-east-1.rds.amazonaws.com
POSTGRES_PORT=5432
POSTGRES_USER=airflow_prod
POSTGRES_PASSWORD=${POSTGRES_PASSWORD_PROD}
POSTGRES_DB=airflow_prod

# RabbitMQ (High availability)
RABBITMQ_HOST=prod-rabbitmq.mq.us-east-1.amazonaws.com
RABBITMQ_PORT=5672
RABBITMQ_USER=${RABBITMQ_USER_PROD}
RABBITMQ_PASSWORD=${RABBITMQ_PASSWORD_PROD}

# Spark (Production EMR)
SPARK_CLUSTER_ID=j-PROD-CLUSTER
SPARK_REGION=us-east-1
SPARK_EXECUTOR_CORES=8
SPARK_EXECUTOR_MEMORY=8g

# Data paths (S3 Production)
DATA_ROOT=s3://data-prod/
BRONZE_PATH=s3://data-prod/bronze/
SILVER_PATH=s3://data-prod/silver/
INTERMEDIATE_PATH=s3://data-prod/intermediate/
GOLD_PATH=s3://data-prod/gold/
DIAMOND_PATH=s3://data-prod/diamond/

# Logging
LOG_LEVEL=WARNING
LOG_FORMAT=json

# Features
ENABLE_QUALITY_CHECKS=true
ENABLE_LINEAGE_TRACKING=true
ENABLE_METRICS_EXPORT=true

# High availability
AIRFLOW__CORE__MAX_ACTIVE_RUNS_PER_DAG=5
AIRFLOW__CORE__PARALLELISM=64
