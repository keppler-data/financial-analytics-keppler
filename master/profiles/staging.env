# Staging Environment Profile

ENVIRONMENT=staging
DEBUG=false

# Database (RDS)
POSTGRES_HOST=staging-postgres.c9akciq32.us-east-1.rds.amazonaws.com
POSTGRES_PORT=5432
POSTGRES_USER=airflow
POSTGRES_PASSWORD=${POSTGRES_PASSWORD_STAGING}
POSTGRES_DB=airflow_staging

# RabbitMQ (Managed)
RABBITMQ_HOST=staging-rabbitmq.mq.us-east-1.amazonaws.com
RABBITMQ_PORT=5672
RABBITMQ_USER=${RABBITMQ_USER_STAGING}
RABBITMQ_PASSWORD=${RABBITMQ_PASSWORD_STAGING}

# Spark (EMR)
SPARK_CLUSTER_ID=j-STAGING-CLUSTER
SPARK_REGION=us-east-1

# Data paths (S3)
DATA_ROOT=s3://data-staging/
BRONZE_PATH=s3://data-staging/bronze/
SILVER_PATH=s3://data-staging/silver/
INTERMEDIATE_PATH=s3://data-staging/intermediate/
GOLD_PATH=s3://data-staging/gold/
DIAMOND_PATH=s3://data-staging/diamond/

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Features
ENABLE_QUALITY_CHECKS=true
ENABLE_LINEAGE_TRACKING=true
ENABLE_METRICS_EXPORT=true
