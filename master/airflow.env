# Airflow Environment Configuration

# Core settings
AIRFLOW__CORE__DAGS_FOLDER=/opt/airflow/dags
AIRFLOW__CORE__PLUGINS_FOLDER=/opt/airflow/plugins
AIRFLOW__CORE__BASE_LOG_FOLDER=/opt/airflow/logs
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__CORE__LOAD_DEFAULT_CONNECTIONS=true
AIRFLOW__CORE__SQL_ALCHEMY_POOL_SIZE=20
AIRFLOW__CORE__SQL_ALCHEMY_POOL_RECYCLE=3600

# Database configuration
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow

# Executor configuration
AIRFLOW__CORE__EXECUTOR=CeleryExecutor
AIRFLOW__CELERY__BROKER_URL=amqp://guest:guest@rabbitmq:5672//
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://airflow:airflow@postgres:5432/airflow

# Webserver configuration
AIRFLOW__WEBSERVER__AUTHENTICATE=true
AIRFLOW__WEBSERVER__AUTH_BACKEND=airflow.contrib.auth.backends.password_auth
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=true

# Email configuration
AIRFLOW__EMAIL__EMAIL_BACKEND=airflow.providers.amazon.aws.utils.email.SendGridEmailBackend

# Logging configuration
AIRFLOW__LOGGING__LOG_FORMAT=[%%(asctime)s] {%%(filename)s:%%(lineno)d} %%(levelname)s - %%(message)s

# Feature toggles
AIRFLOW__CORE__ENABLE_XCOM_PICKLING=true
AIRFLOW__CORE__DEFAULT_POOL_TASK_SLOT_COUNT=128

# Security
AIRFLOW__CORE__SECRET_KEY=your_secret_key_here
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here
