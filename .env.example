# Environment Configuration Template
# Copy this file to .env and fill in your values

# Project Settings
PROJECT_NAME=financial-risk-lakehouse
ENVIRONMENT=dev
DEBUG=true

# Airflow Configuration
AIRFLOW_HOME=/opt/airflow
AIRFLOW_UID=50000
AIRFLOW_PARALLELISM=32
AIRFLOW_MAX_ACTIVE_RUNS_PER_DAG=3

# Database Configuration
POSTGRES_USER=airflow
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=airflow
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET=your-datalake-bucket
S3_BRONZE_PATH=bronze/
S3_SILVER_PATH=silver/
S3_INTERMEDIATE_PATH=intermediate/
S3_GOLD_PATH=gold/
S3_DIAMOND_PATH=diamond/

# RabbitMQ Configuration
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# Spark Configuration
SPARK_MASTER_HOST=spark-master
SPARK_MASTER_PORT=7077
SPARK_EXECUTOR_CORES=4
SPARK_EXECUTOR_MEMORY=4g
SPARK_DRIVER_MEMORY=2g

# API Configuration
API_PORT=8000
API_HOST=0.0.0.0

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Feature Flags
ENABLE_QUALITY_CHECKS=true
ENABLE_LINEAGE_TRACKING=true
ENABLE_ANOMALY_DETECTION=true
ENABLE_FRAUD_DETECTION=true

# Monitoring
ENABLE_METRICS_EXPORT=true
METRICS_PORT=9090

# Security
SECRET_KEY=your-secret-key-here
ENCRYPTION_KEY=your-encryption-key-here
